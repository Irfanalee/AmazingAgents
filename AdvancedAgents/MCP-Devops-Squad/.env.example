# ==========================================
# MCP-DevOps-Squad Configuration Template
# ==========================================
# Copy this file to '.env' and customize it.

# ------------------------------------------
# AI Provider Settings
# ------------------------------------------
# Choose the AI "brain" for the Lead-SRE Orchestrator.
# Supported Providers: google, openai, anthropic, ollama

AI_PROVIDER=google
AI_MODEL=gemini-1.5-pro
# AI_API_KEY is not required for Google if using Application Default Credentials (ADC)
# AI_API_KEY=your_api_key_here

# Example for OpenAI:
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o
# AI_API_KEY=sk-your-openai-api-key

# Example for Anthropic:
# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-5-sonnet-20240620
# AI_API_KEY=sk-ant-your-anthropic-api-key

# Example for Local Ollama (Zero Cost):
# AI_PROVIDER=ollama
# AI_MODEL=llama3
# AI_BASE_URL=http://localhost:11434

# ------------------------------------------
# External Service Credentials
# ------------------------------------------
# Required by the Debugger-Agent's GitHub MCP Server
GITHUB_TOKEN=your_github_personal_access_token

# ------------------------------------------
# MCP Server Overrides (Optional)
# ------------------------------------------
# The default settings use standard 'docker run' commands.
# Uncomment and modify these if you need to use different images,
# run them locally instead of via docker, or pass extra flags.

# Docker MCP (Monitor-Agent)
# DOCKER_MCP_COMMAND=docker
# DOCKER_MCP_ARGS='["run", "-i", "--rm", "mcp/docker-server"]'

# Trivy Security MCP (Sargent-Agent)
# Requires docker socket mount for scanning local images.
# TRIVY_MCP_COMMAND=docker
# TRIVY_MCP_ARGS='["run", "-i", "--rm", "-v", "/var/run/docker.sock:/var/run/docker.sock", "mcp/trivy-server"]'

# GitHub MCP (Debugger-Agent)
# GITHUB_MCP_COMMAND=docker
# GITHUB_MCP_ARGS='["run", "-i", "--rm", "mcp/github-server"]'

# Filesystem MCP (Debugger-Agent)
# Requires mounting the target directory you want to analyze.
# FILESYSTEM_MCP_COMMAND=docker
# FILESYSTEM_MCP_ARGS='["run", "-i", "--rm", "-v", "/:/host", "mcp/filesystem-server"]'

# Shell/CLI MCP (Janitor-Agent)
# SHELL_MCP_COMMAND=docker
# SHELL_MCP_ARGS='["run", "-i", "--rm", "mcp/shell-server"]'
