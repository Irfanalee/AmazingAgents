# Copy this file to .env and fill in your values.
# The app reads the API key from the frontend (stored in localStorage),
# but these vars are available for server-side overrides or tooling.

# Anthropic API key (optional — can be set in the UI instead)
ANTHROPIC_API_KEY=sk-ant-api03-...

# SQLite database path (default: data/mck.db)
DATABASE_URL=sqlite:///./data/mck.db

# Directory for generated export files (default: exports/)
EXPORTS_DIR=exports

# FastAPI host/port (default: 0.0.0.0:8000)
HOST=0.0.0.0
PORT=8000
